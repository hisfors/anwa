# Anwa environment

# Anthropic API key, read server-side only, never exposed to the client.
# The Guide module uses it to generate and translate guided star tours.
# If this is left blank the app still runs: it serves the committed sample
# tour and labels live generation as unavailable. Nothing else needs a key.
ANTHROPIC_API_KEY=

# Model used by the Guide. Leave default unless you have a reason to change it.
ANWA_GUIDE_MODEL=claude-opus-4-8

# Local SQLite database. The seed script writes here. No external DB needed.
DATABASE_URL="file:./dev.db"

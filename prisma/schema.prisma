// Anwa data model. SQLite, file-based, simple. Postgres is the production swap
// (see README: change provider to "postgresql" and DATABASE_URL, nothing else).
// SQLite has no enum type, so status fields are strings validated in application code.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Host {
  id         String   @id @default(cuid())
  name       String // contact person
  familyName String // the camel-farming family, shown to guests
  phone      String
  bio        String
  createdAt  DateTime @default(now())
  sites      Site[]
}

model Site {
  id              String         @id @default(cuid())
  hostId          String
  host            Host           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  name            String
  description     String
  latitude        Float
  longitude       Float
  capacity        Int // maximum party size per night
  offerings       String // comma-separated: what the host provides (camel ride, tea, etc.)
  pricePerPerson  Int // AED per person, a request-to-book figure, not charged
  bortleClass     Int // measured darkness at this exact site, for the listing
  skyBrightness   Float // mag/arcsec^2 at this site
  createdAt       DateTime       @default(now())
  availabilities  Availability[]
  bookings        Booking[]
}

// One row per night the host has opened. Anwa pre-fills these from the Planner's
// top-ranked dark nights, so availability is tied to genuinely good stargazing.
model Availability {
  id               String   @id @default(cuid())
  siteId           String
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  date             DateTime // the night (local date at 21:00)
  score            Int // Planner score 0-100, stored so the listing can show it
  moonIllumination Float // 0-1, stored from the ephemeris for verification
  note             String // short human note, e.g. "new moon, GC high"
  isOpen           Boolean  @default(true)

  @@unique([siteId, date])
}

model Booking {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  guestName   String
  guestEmail  String
  partySize   Int
  date        DateTime
  message     String
  language    String   @default("en") // language the guest wants the tour in
  status      String   @default("REQUESTED") // REQUESTED | CONFIRMED | DECLINED
  createdAt   DateTime @default(now())
}
